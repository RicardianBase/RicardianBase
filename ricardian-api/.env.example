# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=ricardian_dev
DATABASE_USER=ricardian
DATABASE_PASSWORD=

# JWT
JWT_SECRET=                    # min 32 characters
JWT_ACCESS_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d

# App
# Comma-separated origins are supported in production.
CORS_ORIGIN=http://localhost:8080
PORT=3000
NODE_ENV=development

# AI Contract Review (optional)
# If unset, the /contracts/ai/review endpoint returns 503 and the
# `ai_contract_review` feature flag is reported as false.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-6
